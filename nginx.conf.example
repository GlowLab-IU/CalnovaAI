server {
    listen 80;
    server_name calnovaai.com www.calnovaai.com;

    root /var/www/calnovaai;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Optional: Cache static assets
    location /static/ {
        expires 1y;
        add_header Cache-Control "public";
    }
}
